# Runtime mode: demo | test | staging | prod
ADMITPILOT_RUN_MODE=demo
ADMITPILOT_TIMEZONE=Asia/Shanghai
ADMITPILOT_LOG_LEVEL=INFO
ADMITPILOT_DEFAULT_CYCLE=2026
ADMITPILOT_OFFICIAL_LIBRARY_PATH=data/official_library/official_library.json
ADMITPILOT_CASE_LIBRARY_PATH=data/case_library/case_library.json

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
# Leave empty to auto-select: demo/staging/prod -> embedding, test -> fake
ADMITPILOT_SEMANTIC_MATCHER_KIND=

# Service
ADMITPILOT_API_HOST=127.0.0.1
ADMITPILOT_API_PORT=8000
ADMITPILOT_API_DATA_PATH=.admitpilot/admitpilot.sqlite3

# External stores
ADMITPILOT_DATABASE_URL=
ADMITPILOT_REDIS_URL=
ADMITPILOT_OBJECT_STORE_ENDPOINT=
ADMITPILOT_OBJECT_STORE_BUCKET=admitpilot-artifacts
ADMITPILOT_OBJECT_STORE_ACCESS_KEY=
ADMITPILOT_OBJECT_STORE_SECRET_KEY=
